<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="piper">
  <xacro:arg
    name="initial_positions_file"
    default="$(find piper_gripper_moveit_config)/config/gazebo_initial_positions.yaml"/>
  <xacro:arg
    name="controllers_file"
    default="$(find piper_gripper_moveit_config)/config/gazebo_ros2_controllers.yaml"/>

  <xacro:include
    filename="$(find agx_arm_description)/agx_arm_urdf/piper/urdf/piper_with_gripper_description.xacro"/>
  <xacro:include filename="piper.gazebo.ros2_control.xacro"/>

  <xacro:piper_gazebo_ros2_control
    name="GazeboSystem"
    initial_positions_file="$(arg initial_positions_file)"
    controllers_file="$(arg controllers_file)"/>

  <!-- Improve contact stability for the two gripper fingers. -->
  <gazebo reference="gripper_link1">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>
  <gazebo reference="gripper_link2">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>
</robot>
